# 5 - completion
completion:
  dataset-mapping: _dataset_mapping.csv
  feature-mapping: _feature_mapping.csv
  features: 
    legal:
    - "column_to_preserve"
    biomedical:
    - "column_to_preserve"
    heritage:
    - "column_to_preserve"

# 6 - downsampling
downsampling:
  seed: 42
  plain-text:
    text-column: text
    source-column: source_id
    special-input-file: ""
    tasks:

      # INPUT: Corpus
      # - S fuentes diferentes (valores en la columna "source_id")
      # - N documentos (filas en el dataframe), 
      # - NSi número de documentos por fuente Si (filas en el dataframe con source_id=Si)
      # - T número total de tokens totales (suma de todos los documentos)
      # - TSi número total de tokens por fuente Si (suma de todos los documentos de la fuente Si)

      # Tarea 1: Downsampling del corpus a un objetivo de tokens T' de manera estratificada
      - type: tokens_general_stratified
        params:
          target: 100 

      # # Tarea 2: Downsampling del corpus a un objetivo de tokens T' de manera equitativa
      # - type: tokens_general_equitative
      #   params:
      #     target: 100

      # # Tarea 3: Downsampling del corpus a un objetivo de tokens TSi' por fuente Si (con i=1..S)
      # - type: tokens_per_source
      #   params:
      #     mapping:
      #       "source_id_example": 100

      # # Tarea 4: Downsampling del corpus a un objetivo de documentos N' de manera estratificada
      # - type: documents_general_stratified
      #   params:
      #     target: 100
      
      # # Tarea 5: Downsampling del corpus a un objetivo de documentos N' de manera equitativa
      # - type: documents_general_equitative
      #   params:
      #     target: 100
      
      # # Tarea 6: Downsampling del corpus a un objetivo de documentos NSi' por fuente Si (con i=1..S)
      # - type: documents_per_source
      #   params:
      #     mapping:
      #       "source_id_example": 100